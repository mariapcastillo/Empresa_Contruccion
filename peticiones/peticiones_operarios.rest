### ================================
### 1. LISTAR OPERARIOS
### ================================

GET {{baseUrl}}/admin/operarios
Authorization: Bearer {{adminToken}}
Content-Type: application/json

### ================================
### 2. OBTENER OPERARIO POR ID
### ================================

GET {{baseUrl}}/admin/operarios/101
Authorization: Bearer {{adminToken}}
Content-Type: application/json

### ================================
### 3. CREAR OPERARIO
### usa el user_id 127 que es nuevo
### ================================

POST {{baseUrl}}/admin/operarios
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "user_id": 127,
  "especialidad": "Impermeabilización",
  "estado": "disponible",
  "localizacion": "Boadilla",
  "telefono": "600100021"
}

### ================================
### 4. ACTUALIZAR OPERARIO
### ================================

PUT {{baseUrl}}/admin/operarios/120
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "especialidad": "Impermeabilización avanzada",
  "estado": "ocupado",
  "localizacion": "Boadilla Norte",
  "telefono": "600100099"
}

### ================================
### 5. ELIMINAR OPERARIO
### ================================

DELETE {{baseUrl}}/admin/operarios/120
Authorization: Bearer {{adminToken}}
Content-Type: application/json